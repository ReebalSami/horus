# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# uv (manages .venv automatically; lockfile committed)
.venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter / notebook discipline (B2=A: jupytext .py only, no .ipynb checked in)
.ipynb_checkpoints/
*.ipynb
# Consumer override pattern: place a .gitkeep in a subdir under experiments/
# named '.ipynb_keep/' if you genuinely need to track an .ipynb (rare).

# Experiment outputs from `make experiment`
experiments/*.executed.ipynb
experiments/*.executed.py

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# ML artifacts (consumer customizes if any of these are tracked)
artifacts/
checkpoints/
mlruns/
wandb/
tb_logs/
lightning_logs/

# M2D.5 issue #8: data/ corpus root gitignored (brainstorm §8)
# Only data/README.md is tracked; use `git add -f data/<path>` for deliberate exceptions.
data/*
!data/README.md

# M2D.5 issue #9 (ADR-005): tools/ at repo root holds downloaded Java tools
# (Mustang JAR). JAR fetched + checksum-verified via `make mustang-jar`.
# Never committed. Anchored with leading slash so it doesn't shadow nested
# tools/ paths (e.g., docs/sources/tools/).
/tools/
