__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# uv (manages .venv automatically; lockfile committed)
.venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter / notebook discipline (B2=A: jupytext .py only, no .ipynb checked in)
.ipynb_checkpoints/
*.ipynb
# Consumer override pattern: place a .gitkeep in a subdir under experiments/
# named '.ipynb_keep/' if you genuinely need to track an .ipynb (rare).

# Experiment outputs from `make experiment`
experiments/*.executed.ipynb
experiments/*.executed.py

# ADR-024 + ADR-025: Quarto build artifacts (`make eda` + `make eda-book`).
# Source-of-truth is the .py:percent files + .qmd files (tracked); HTML/PDF
# + Quarto's per-document and project-level execution caches are transient
# and never committed.
experiments/*.html
experiments/*.pdf
experiments/.quarto/
/_book/
/_freeze/
.quarto/

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

