artifacts/
checkpoints/
mlruns/
mlartifacts/
mlflow.db
mlflow.db-journal
wandb/
tb_logs/
lightning_logs/

# M2D.5 issue #8: data/ corpus root gitignored (brainstorm §8)
# Only data/README.md is tracked; use `git add -f data/<path>` for deliberate exceptions.
data/*
!data/README.md
# M2D.5 issue #12: git-track MANIFEST.md per dataset as the per-corpus audit-trail record.
# Git rule: a file inside an ignored directory cannot be un-ignored via `!` patterns.
# Fix: un-ignore the full directory chain, re-ignore everything at each level,
# then selectively un-ignore MANIFEST.md at the leaf (data/raw/<lang>/<slug>/) level.
# Layout is flat: data/raw/<lang>/<slug>/ — depth is fixed, so explicit patterns work.
!data/raw/
data/raw/*
!data/raw/german/
!data/raw/english/
!data/raw/korean/
!data/raw/multilingual/
data/raw/german/*
data/raw/english/*
data/raw/korean/*
data/raw/multilingual/*
!data/raw/german/*/
!data/raw/english/*/
!data/raw/korean/*/
!data/raw/multilingual/*/
data/raw/german/*/*
data/raw/english/*/*
data/raw/korean/*/*
data/raw/multilingual/*/*
!data/raw/german/*/MANIFEST.md
!data/raw/english/*/MANIFEST.md
!data/raw/korean/*/MANIFEST.md
!data/raw/multilingual/*/MANIFEST.md

# M2D.5 issue #9 (ADR-005): tools/ at repo root holds downloaded Java tools
# (Mustang JAR). JAR fetched + checksum-verified via `make mustang-jar`.
# Never committed. Anchored with leading slash so it doesn't shadow nested
# tools/ paths (e.g., docs/sources/tools/).
/tools/

# ADR-016: adapters_candidate.py is the developer's in-progress candidate
# adapter for the adapter-iterate dev loop (issue #51). Never committed —
# when satisfied, copy candidate over `adapters.py` via PR + delete the
# candidate file. The canonical adapter lives at src/horus/eval/adapters.py;
# the candidate is a working file, not a source-of-truth artifact.
src/horus/eval/adapters_candidate.py

# ADR-016 + ADR-017: dev-cohort transcript archives produced by
# `pilot-13-dev*.yaml` overlays (`dev_only: true` configs). Per the
# HARKing-prevention contract, dev transcripts MUST NEVER contaminate
# the canonical 182-tuple `docs/sources/transcripts-multipage/` archive.
# The canonical archive (no `-dev*` suffix) IS tracked.
docs/sources/transcripts-multipage-dev/
docs/sources/transcripts-multipage-dev-mlx/
docs/sources/transcripts-multipage-dev-2x2/
# ADR-032 (#77) H8 efficiency-sweep transcripts — perf-run byproduct, dev_only.
docs/sources/transcripts-multipage-h8/
# ADR-038 (#91) extraction-arms dev-run transcripts (Granite reads + Gemma
# structured outputs) — dev_only configs; regenerable via `make` (see ADR-038
# §Dev-run validation). Never contaminate the canonical archive.
docs/sources/transcripts-arms-dev/
docs/sources/transcripts-arm-a-dev/

# Serena MCP tool — manages its own cache via .serena/.gitignore
.serena/

/.quarto/
**/*.quarto_ipynb
