# Copy to `.env` (gitignored) and customize.

# uv PyTorch wheel backend autodetect (per python-ml-uv brainstorm B3=A).
# Auto-detects MPS (macOS) / CUDA (Linux+GPU) / CPU at install time.
# Override with a specific backend if needed: cpu | cu130 | cu128 | mps | rocm
# See: https://docs.astral.sh/uv/guides/integration/pytorch/
UV_TORCH_BACKEND=auto
